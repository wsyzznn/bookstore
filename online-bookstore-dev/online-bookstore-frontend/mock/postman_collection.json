{
  "info": {
    "name": "Online Bookstore API",
    "description": "在线书店 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "认证 Auth",
      "item": [
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "管理员登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "商家登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"merchant1\",\n  \"password\": \"merchant123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"password123\",\n  \"email\": \"newuser@example.com\",\n  \"phone\": \"13900000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "退出登录",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "图书 Books",
      "item": [
        {
          "name": "获取图书列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books?page=1&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "搜索图书",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books?keyword=JavaScript&page=1&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"],
              "query": [
                { "key": "keyword", "value": "JavaScript" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "按分类筛选图书",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books?category=编程",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"],
              "query": [
                { "key": "category", "value": "编程" }
              ]
            }
          }
        },
        {
          "name": "获取图书详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "添加图书 (商家)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"新书标题\",\n  \"author\": \"作者名\",\n  \"isbn\": \"978-7-000-00000-0\",\n  \"price\": 59.00,\n  \"stock\": 100,\n  \"cover\": \"https://example.com/cover.jpg\",\n  \"description\": \"这是一本新书\",\n  \"category\": \"编程\",\n  \"merchantId\": 1,\n  \"merchantName\": \"技术书店\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "更新图书",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"更新后的书名\",\n  \"price\": 88.00,\n  \"stock\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "删除图书",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "商家图书列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/merchant/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchant", "books"]
            }
          }
        }
      ]
    },
    {
      "name": "购物车 Cart",
      "item": [
        {
          "name": "获取购物车",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "添加到购物车",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 3,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "更新购物车数量",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "1"]
            }
          }
        },
        {
          "name": "删除购物车项",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cart/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "1"]
            }
          }
        },
        {
          "name": "清空购物车",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        }
      ]
    },
    {
      "name": "订单 Orders",
      "item": [
        {
          "name": "获取我的订单",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "获取订单详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1"]
            }
          }
        },
        {
          "name": "创建订单",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressId\": 1,\n  \"items\": [\n    { \"bookId\": 1, \"quantity\": 2 },\n    { \"bookId\": 2, \"quantity\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "更新订单状态",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SHIPPED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1", "status"]
            }
          }
        },
        {
          "name": "管理员-所有订单",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "orders"]
            }
          }
        }
      ]
    },
    {
      "name": "地址 Addresses",
      "item": [
        {
          "name": "获取地址列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/addresses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "addresses"]
            }
          }
        },
        {
          "name": "添加地址",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver\": \"王五\",\n  \"phone\": \"13900000005\",\n  \"province\": \"广东省\",\n  \"city\": \"深圳市\",\n  \"district\": \"南山区\",\n  \"detail\": \"科技园路100号\",\n  \"isDefault\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/addresses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "addresses"]
            }
          }
        },
        {
          "name": "更新地址",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver\": \"张三(更新)\",\n  \"isDefault\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/addresses/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "addresses", "1"]
            }
          }
        },
        {
          "name": "删除地址",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/addresses/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "addresses", "2"]
            }
          }
        }
      ]
    },
    {
      "name": "用户管理 Admin",
      "item": [
        {
          "name": "获取用户列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "更新用户信息",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"MERCHANT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "3"]
            }
          }
        },
        {
          "name": "删除用户",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "3"]
            }
          }
        }
      ]
    }
  ]
}
